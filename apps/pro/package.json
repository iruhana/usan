{
  "name": "usan-pro",
  "version": "0.1.0",
  "description": "Usan — Multi-AI Hub with Skills Engine",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win --config electron-builder.json5",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:smoke": "vitest run src/renderer/src/__tests__/app-shell.smoke.test.tsx src/renderer/src/__tests__/composer-chat.integration.test.tsx",
    "test:a11y": "vitest run src/renderer/src/__tests__/app-shell.a11y.test.tsx",
    "test:e2e:electron": "npm run build && npm run test:e2e:electron:compiled",
    "test:e2e:electron:compiled": "node scripts/run-electron-smoke.mjs",
    "phase0:readiness": "node scripts/report-phase0-readiness.mjs",
    "phase0:ci-status": "node scripts/report-phase0-ci-status.mjs",
    "phase0:ci-compare": "node scripts/report-phase0-ci-compare.mjs",
    "phase0:ci-observe": "node scripts/run-phase0-ci-observe.mjs",
    "phase0:closeout": "node scripts/report-phase0-closeout.mjs",
    "phase0:commit-handoff": "node scripts/report-phase0-commit-handoff.mjs",
    "phase0:commit-dry-run": "node scripts/report-phase0-commit-dry-run.mjs",
    "phase0:publish-status": "node scripts/report-phase0-publish-status.mjs",
    "phase0:simulate-publish": "node scripts/report-phase0-simulate-publish.mjs",
    "phase0:stage-scope": "node scripts/report-phase0-stage-scope.mjs",
    "phase0:push-handoff": "node scripts/report-phase0-push-handoff.mjs",
    "phase0:push-script": "node scripts/report-phase0-push-script.mjs",
    "phase0:push-script-whatif": "node scripts/report-phase0-push-script-whatif.mjs",
    "phase0:evidence-manifest": "node scripts/report-phase0-evidence-manifest.mjs",
    "phase0:bundle-evidence": "node scripts/report-phase0-bundle-evidence.mjs",
    "phase0:bundle-verify": "node scripts/report-phase0-bundle-verify.mjs",
    "phase0:publish-readiness": "node scripts/report-phase0-publish-readiness.mjs",
    "verify:strict:legacy": "npm run typecheck && npm run lint && npm run test:smoke && npm run test:a11y && npm run test && npm run build && npm run test:e2e:electron:compiled && npm run phase0:readiness",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "verify:strict": "node scripts/run-verify-strict.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "allotment": "^1.20.5",
    "better-sqlite3": "^12.6.2",
    "cmdk": "^1.1.1",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.6.0",
    "lucide-react": "^0.475.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "playwright-core": "^1.58.2",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.3.0",
    "vitest": "^4.1.0"
  }
}
