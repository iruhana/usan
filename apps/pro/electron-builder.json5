{
  appId: "com.usan.pro",
  productName: "Usan",
  directories: {
    buildResources: "build",
    output: "dist"
  },
  files: ["out/**/*", "!**/*.map"],
  win: {
    executableName: "usan",
    target: [{ target: "nsis", arch: ["x64"] }]
  },
  nsis: {
    oneClick: false,
    perMachine: false,
    allowToChangeInstallationDirectory: true,
    deleteAppDataOnUninstall: false
  }
}
