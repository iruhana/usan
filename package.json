{
  "name": "usan-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Usan (우산) — AI Personal Secretary",
  "scripts": {
    "dev:desktop": "cd apps/desktop && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "lint": "cd apps/desktop && npm run lint",
    "build:desktop": "cd apps/desktop && npm run build",
    "build:web": "cd apps/web && npm run build",
    "test": "cd apps/desktop && npm test",
    "typecheck": "cd apps/desktop && npm run typecheck",
    "install:all": "cd apps/desktop && npm install && cd ../web && npm install"
  }
}
